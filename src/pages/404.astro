---
import Base from '../layouts/Base.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../content/site.config';
---
<Base title={`${SITE.name} / Not found`} description="The page you requested does not exist on oxygn.xyz.">
  <Navigation />
  <main>
    <section class="section" style="text-align:center;min-height:55svh;display:grid;align-content:center">
      <div class="container">
        <p class="eyebrow">404</p>
        <h1 class="nf-title">Nothing here.</h1>
        <p class="nf-sub">The page you requested does not exist on {SITE.domain}.</p>
        <div class="nf-acts"><a href="/" class="btn btn-primary">Back to Oxygn</a><a href="/services" class="btn btn-outline">Explore services</a></div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
<style>
  .nf-title { font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: var(--text-2xl); line-height: 0.96; letter-spacing: -0.02em; color: var(--ink); margin-top: 0.3rem; }
  .nf-sub { font-size: var(--text-sm); color: var(--ink-light); max-width: 36ch; margin: 0.5rem auto 0; }
  .nf-acts { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; margin-top: 1.25rem; }
</style>
