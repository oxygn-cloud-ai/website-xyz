---
import Base from '../layouts/Base.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { SITE, TRUST_STANDARDS, JURISDICTIONS } from '../content/site.config';
---
<Base title={`${SITE.name} / Trust & Security`} description="Enterprise-grade security. Operator standards above any regulator's minimum.">
  <Navigation />

  <main>
    <section class="section page-head" aria-labelledby="ph">
      <div class="container">
        <p class="eyebrow">Trust &amp; Security</p>
        <h1 class="display" style="font-size:var(--text-xl);line-height:1.05;letter-spacing:-0.015em" id="ph">Operator standards above<br/>any regulator's minimum.</h1>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <h2 class="display" style="font-size:var(--text-lg);line-height:1.08;letter-spacing:-0.01em">How we protect your data and regulatory standing.</h2>
        <div class="grid-3" style="margin-top:var(--block-gap)">
          {TRUST_STANDARDS.map(s => (<div><h3 class="ts-t">{s.title}</h3><p class="ts-d">{s.description}</p></div>))}
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="ce-h">
      <div class="container">
        <h2 class="display" style="font-size:var(--text-lg);line-height:1.08;letter-spacing:-0.01em" id="ce-h">Certifications and regulatory alignment.</h2>
        <div class="grid-2" style="margin-top:var(--block-gap)">
          <div><h3 class="ch">Certifications</h3><ul class="cl"><li>SOC 2 Type II</li><li>ISO 27001</li><li>ISO 27017</li><li>ISO 27018</li></ul></div>
          <div><h3 class="ch">Regulatory alignment</h3><ul class="cl"><li>MAS Notice 644 cyber-incident posture</li><li>MAS Technology Risk Management Guidelines</li><li>MAS FEAT principles</li><li>Annual third-party penetration testing</li><li>Continuous external red-team exercises</li></ul></div>
        </div>
      </div>
    </section>

    <section class="section section-dark" aria-labelledby="dr-h">
      <div class="container">
        <h2 class="display" style="font-size:var(--text-lg);line-height:1.08;letter-spacing:-0.01em;color:var(--paper)" id="dr-h">Data residency.</h2>
        <div class="rtable" style="margin-top:var(--block-gap)">
          {JURISDICTIONS.map(j => (<div class="rrow"><span class="rm">{j.market}</span><span class="rr">{j.regulator}</span><span class="rs">{j.status}</span></div>))}
        </div>
        <p class="section-body" style="margin-top:var(--block-gap)">Singapore-region data residency by default. Per-market residency for each expansion market. No transit through non-common-law jurisdictions without per-purpose written consent.</p>
      </div>
    </section>

    <section class="section" aria-labelledby="pi-h">
      <div class="container">
        <h2 class="display" style="font-size:var(--text-lg);line-height:1.08;letter-spacing:-0.01em" id="pi-h">Professional standing.</h2>
        <div class="grid-3" style="margin-top:var(--block-gap)">
          <div><h3 class="pi-t">Professional Indemnity insurance</h3><p class="pi-d">Sized to MPI, SPI, and CMS-scale liability. Certificates available on request.</p></div>
          <div><h3 class="pi-t">Cyber insurance</h3><p class="pi-d">Separate cyber policy. 24/7 incident response. MAS Notice 644 posture maintained.</p></div>
          <div><h3 class="pi-t">Capital and continuity</h3><p class="pi-d">Adequate operating runway. Tested business continuity and disaster recovery plans. External audit annually.</p></div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .section-body { font-size: var(--text-base); line-height: 1.55; color: var(--ink-light); max-width: var(--measure); margin-top: 0.75rem; }
  .ts-t { font-size: var(--text-md); font-weight: 500; color: var(--ink); }
  .ts-d { font-size: var(--text-sm); color: var(--ink-light); line-height: 1.55; margin-top: 0.2rem; }
  .ch { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-faint); text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.75rem; }
  .cl { list-style: none; display: grid; gap: 0.35rem; }
  .cl li { font-size: var(--text-sm); color: var(--ink-light); padding-left: 1rem; position: relative; }
  .cl li::before { content: ''; position: absolute; left: 0; top: 0.45em; width: 0.35rem; height: 0.35rem; border-radius: 50%; background: var(--accent); }
  .rtable { border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius); overflow: hidden; }
  .rrow { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.5rem; padding: 1rem var(--card-pad); border-bottom: 1px solid rgba(255,255,255,0.06); align-items: center; font-size: var(--text-sm); }
  .rrow:last-child { border-bottom: 0; }
  .rm { font-weight: 500; color: var(--paper); }
  .rr { color: rgba(255,255,255,0.45); }
  .rs { font-family: var(--font-mono); font-size: var(--text-xs); color: rgba(255,255,255,0.25); text-align: right; }
  .pi-t { font-size: var(--text-md); font-weight: 500; color: var(--ink); }
  .pi-d { font-size: var(--text-sm); color: var(--ink-light); line-height: 1.55; margin-top: 0.2rem; }
</style>
