---
import Base from '../layouts/Base.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { SITE, SERVICES } from '../content/site.config';
---
<Base title={`${SITE.name} / AI-native governance, risk, and compliance`} description={SITE.tagline}>
  <Navigation />

  <main>
    <section class="section" aria-labelledby="hero-h" style="text-align:center;padding-block-end:1rem">
      <div class="container">
        <h1 class="hero-title" id="hero-h">The cost of execution collapsed.<br/>The cost of governance didn't.</h1>
        <p class="hero-sub">Six service lines. One AI workforce. Continuous, auditable, regulator-grade delivery for Singapore-licensed financial institutions.</p>
        <div class="hero-acts">
          <a href="/platform" class="btn btn-primary">See how it works</a>
          <a href="/contact" class="btn btn-outline">Request a demo</a>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="svc-h">
      <div class="container">
        <div class="grid-3">
          {SERVICES.map(s => (<ServiceCard title={s.title} description={s.description} bundles={s.bundles} href="/services" />))}
        </div>
      </div>
    </section>

    <section class="section section-dark" style="text-align:center">
      <div class="container">
        <h2 class="display" style="font-size:var(--text-2xl);line-height:0.96;letter-spacing:-0.02em;color:var(--paper);max-width:20ch;margin:0 auto">Your licence requires a compliance function worth defending.</h2>
        <p class="section-body" style="max-width:40ch;margin:0.75rem auto 0;text-align:center">We would like to show you how we build one.</p>
        <div style="margin-top:1.5rem"><a href="/contact" class="btn btn-primary">Request a demo</a></div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .hero-title { font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: var(--text-3xl); line-height: 0.94; letter-spacing: -0.025em; color: var(--ink); max-width: 16ch; margin: 0 auto; }
  .hero-sub { font-size: var(--text-base); color: var(--ink-light); max-width: 44ch; margin: 1rem auto 0; line-height: 1.5; }
  .hero-acts { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; margin-top: 1.5rem; }
  .section-body { font-size: var(--text-base); line-height: 1.55; color: var(--ink-light); max-width: var(--measure); margin-top: 0.75rem; }
</style>
