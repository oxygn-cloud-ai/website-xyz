---
import { SITE, FOOTER_LINKS } from '../content/site.config';
---
<footer class="foot">
  <div class="foot-inner">
    <div class="foot-grid">
      <div class="foot-col">
        <span class="foot-wordmark">oxygn<sup>ai</sup></span>
        <p class="foot-tagline">{SITE.tagline}</p>
        <a href={`mailto:${SITE.email}`} class="foot-email">{SITE.email}</a>
      </div>
      <div class="foot-col">
        <h4 class="foot-heading">Services</h4>
        <ul class="foot-list">
          {FOOTER_LINKS.services.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="foot-col">
        <h4 class="foot-heading">Company</h4>
        <ul class="foot-list">
          {FOOTER_LINKS.company.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="foot-col">
        <h4 class="foot-heading">Markets</h4>
        <ul class="foot-list">
          {FOOTER_LINKS.jurisdiction.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; {new Date().getFullYear()} Oxygn Pte Ltd. Singapore.</span>
      <span>{SITE.domain}</span>
    </div>
  </div>
</footer>

<style>
  .foot { border-top: var(--rule); padding-block: 4rem 2rem; }
  .foot-inner { max-width: 72rem; margin: 0 auto; padding: 0 var(--gutter); }

  .foot-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--block-gap);
  }
  @media (min-width: 40rem) { .foot-grid { grid-template-columns: 1.5fr 1fr 1fr 1fr; } }

  .foot-col { display: grid; gap: 0.75rem; align-content: start; }

  .foot-wordmark {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: var(--text-lg);
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .foot-wordmark sup {
    font-size: 0.38em;
    font-weight: 300;
    margin-left: 0.06em;
    color: var(--accent);
  }

  .foot-tagline { font-size: var(--text-sm); color: var(--ink-light); max-width: 28ch; }
  .foot-email {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    transition: opacity var(--transition);
  }
  .foot-email:hover { opacity: 0.6; }

  .foot-heading {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
    margin-bottom: 0.25rem;
  }

  .foot-list { list-style: none; display: grid; gap: 0.35rem; }
  .foot-list a {
    font-size: var(--text-sm);
    color: var(--ink-light);
    transition: color var(--transition);
  }
  .foot-list a:hover { color: var(--ink); }

  .foot-bottom {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: var(--rule);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
