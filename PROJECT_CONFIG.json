{
  "schemaVersion": 2,
  "project": {
    "name": "website-xyz",
    "type": "software",
    "description": "oxygn.xyz company website (Astro 4.x static marketing site)"
  },
  "repo": {
    "provider": "github",
    "github": {
      "owner": "oxygn-cloud-ai",
      "repo": "website-xyz",
      "defaultBranch": "main",
      "issuesEnabled": false,
      "branchProtection": {
        "requiredStatusChecks": [
          "test"
        ],
        "strict": false,
        "enforceAdmins": false,
        "allowForcePushes": false,
        "allowDeletions": false
      }
    }
  },
  "jira": {
    "projectKey": "AI1",
    "cloudId": "f613a24a-e1b0-4b8a-a06a-54d9fa6e9e45",
    "epicKey": "AI1-293",
    "boardUrl": "https://oxygn.atlassian.net/browse/AI1-293"
  },
  "sessions": {
    "roles": [
      "master",
      "planner",
      "implementer",
      "fixer",
      "versioner",
      "chk1",
      "chk2",
      "performance",
      "playtester",
      "reviewer",
      "triager",
      "health",
      "learner",
      "releaser",
      "researcher"
    ]
  },
  "env": {
    "project": {},
    "sessions": {}
  },
  "coverage": {
    "tool": "vitest",
    "thresholds": {}
  },
  "sandbox": {
    "type": "docker",
    "setupInstructions": "Build via `npm run build`, then serve dist/ inside an isolated container. Example: `docker run --rm -p 8080:8080 -v $(pwd)/dist:/app/dist node:20-alpine npx serve /app/dist -l 8080`. Pin a port outside dev defaults."
  },
  "servers": {
    "production": "https://oxygn.xyz"
  },
  "deviations": [
    {
      "check": "17 (timeoutMinutes)",
      "reason": "timeoutMinutes is not required by PROJECT_CONFIG.schema.json; _lib.sh handles missing values gracefully. Adding aspirational fields would be noise."
    }
  ],
  "loops": {
    "master": {
      "intervalMinutes": 5,
      "driver": "session",
      "prompt": "loops/master.md",
      "stateFile": ".claude/state/master.md"
    },
    "triager": {
      "intervalMinutes": 5,
      "driver": "session",
      "prompt": "loops/triager.md",
      "stateFile": ".claude/state/triager.md"
    },
    "reviewer": {
      "intervalMinutes": 5,
      "driver": "session",
      "prompt": "loops/reviewer.md",
      "stateFile": ".claude/state/reviewer.md"
    },
    "chk1": {
      "intervalMinutes": 15,
      "driver": "session",
      "prompt": "loops/chk1.md",
      "stateFile": ".claude/state/chk1.md"
    },
    "chk2": {
      "intervalMinutes": 15,
      "driver": "session",
      "prompt": "loops/chk2.md",
      "stateFile": ".claude/state/chk2.md"
    },
    "fixer": {
      "intervalMinutes": 5,
      "driver": "session",
      "prompt": "loops/fixer.md",
      "stateFile": ".claude/state/fixer.md"
    },
    "implementer": {
      "intervalMinutes": 5,
      "driver": "session",
      "prompt": "loops/implementer.md",
      "stateFile": ".claude/state/implementer.md"
    },
    "versioner": {
      "intervalMinutes": 10,
      "driver": "session",
      "prompt": "loops/versioner.md",
      "stateFile": ".claude/state/versioner.md"
    },
    "performance": {
      "intervalMinutes": 15,
      "driver": "session",
      "prompt": "loops/performance.md",
      "stateFile": ".claude/state/performance.md"
    },
    "playtester": {
      "intervalMinutes": 15,
      "driver": "session",
      "prompt": "loops/playtester.md",
      "stateFile": ".claude/state/playtester.md"
    },
    "health": {
      "intervalMinutes": 5,
      "driver": "session",
      "prompt": "loops/health.md",
      "stateFile": ".claude/state/health.md"
    },
    "learner": {
      "intervalMinutes": 15,
      "driver": "session",
      "prompt": "loops/learner.md",
      "stateFile": ".claude/state/learner.md"
    },
    "releaser": {
      "intervalMinutes": 10,
      "driver": "session",
      "prompt": "loops/releaser.md",
      "stateFile": ".claude/state/releaser.md"
    }
  }
}
